{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],

    "strict": true,
    "noFallthroughCasesInSwitch": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/app/components/aurora-background.tsx",
    "src/app/components/brand-panel.tsx",
    "src/app/components/glass-card.tsx",
    "src/app/components/tab-switcher.tsx",
    "src/app/components/register-form.tsx",
    "src/app/components/signin-form.tsx",
    "src/app/components/mobile-brand-header.tsx",
    "src/app/components/amber-button.tsx",
    "src/app/components/input-field.tsx",
    "src/app/components/church-setup-wizard.tsx",
    "src/app/components/success-screen.tsx"
  ]
}
